# Copy to `.env` in the repository root or next to `examples/main.py`:
#   cp examples/.env.example .env
# Values are loaded before reading `os.environ`; existing shell vars are not overwritten.
#
# --- Zerodha Kite Connect (historical OHLCV in examples/main.py)
# https://kite.trade/docs/connect/v3/
# Access token expires daily (generate a new one after login). HTTP 403 on /historical
# usually means expired token, wrong API key for that token, or missing Historical API access.
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# --- Binance (optional)
# Public klines do not require keys; use when you add signed / private endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- CoinDCX (optional)
# Public candles do not require keys; use for authenticated trading APIs.
COINDCX_API_KEY=
COINDCX_API_SECRET=

# --- Bandl client tuning (optional; reserved for future BandlConfig.from_env)
# BANDL_HTTP_TIMEOUT_SECONDS=30
# BANDL_MAX_HTTP_RETRIES=3
# BANDL_DEFAULT_CRYPTO_PROVIDER=binance
# BANDL_DEFAULT_EQUITY_PROVIDER=zerodha
